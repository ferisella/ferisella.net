---
interface Props {
  items: Array<{
    title: string;
    description?: string;
    link?: string;
  }>;
}

const { items } = Astro.props;
---

<div class="threads">
  {items.slice(0, 3).map((item) => (
    <div class="thread" {item.link ? `data-link="${item.link}"` : ''}>
      <div class="thread-title">{item.title}</div>
      {item.description && <p>{item.description}</p>}
    </div>
  ))}
</div>

<style>
  .threads {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin: 60px 0;
  }
  .thread {
    padding: 20px;
    border: 1px solid var(--rule);
    background: var(--bg-alt);
  }
  .thread-title {
    font-family: var(--display);
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .thread p {
    font-size: 14px;
    line-height: 1.5;
  }
</style>
