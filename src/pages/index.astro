---
import { getCollection } from 'astro:content';

const highlights = await getCollection('highlights');
const releases = await getCollection('releases');
const collaborators = await getCollection('collaborators');

const highlightsData = highlights[0]?.data.items || [];
const releasesList = releases.sort((a, b) => b.data.year - a.data.year);
const allCollaborators = collaborators.sort((a, b) => a.data.name.localeCompare(b.data.name));
const priorityNames = ['Brian Eno', 'Mercedes Sosa', 'Matthew Herbert', 'Matthew Dear', 'James Ellis Ford'];
const collaboratorsList = [
  ...priorityNames.map(name => allCollaborators.find(c => c.data.name === name)).filter(Boolean),
  ...allCollaborators.filter(c => !priorityNames.includes(c.data.name)),
];
---

